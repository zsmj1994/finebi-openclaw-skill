{
  "name": "finebi-openclaw-skill-workspace",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "build": "pnpm run build:sdk && pnpm run build:cli",
    "build:sdk": "pnpm -C packages/querydata-sdk build",
    "build:cli": "pnpm -C packages/finebicli build",
    "typecheck": "pnpm run typecheck:sdk && pnpm run typecheck:cli",
    "typecheck:sdk": "pnpm -C packages/querydata-sdk typecheck",
    "typecheck:cli": "pnpm -C packages/finebicli typecheck",
    "test": "pnpm --filter finebi-cli test",
    "test:coverage": "pnpm --filter finebi-cli test:coverage",
    "clean": "pnpm --filter finebi-cli clean",
    "release:check:sdk": "pnpm run typecheck:sdk && pnpm run build:sdk && pnpm run pack:sdk",
    "release:check:cli": "pnpm -C packages/finebicli test && pnpm run typecheck:cli && pnpm run build:cli && pnpm run pack:cli",
    "release:check:core": "pnpm run release:check:sdk && pnpm run release:check:cli",
    "pack:sdk": "pnpm -C packages/querydata-sdk pack",
    "pack:cli": "pnpm -C packages/finebicli pack",
    "pack:skills": "pnpm -C packages/skills pack",
    "pack:all": "pnpm run pack:sdk && pnpm run pack:cli && pnpm run pack:skills",
    "release:skills": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-finebi-skills.ps1 -Target ClawHub",
    "release:skills:zip": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-finebi-skills.ps1 -Target ZipOnly",
    "release:skills:zip:dry-run": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-finebi-skills.ps1 -Target ZipOnly -DryRun",
    "release:skills:github": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-finebi-skills.ps1 -Target GitHub",
    "publish:sdk": "pnpm -C packages/querydata-sdk run publish:npm",
    "publish:cli": "pnpm -C packages/finebicli run publish:npm",
    "publish:skills": "pnpm -C packages/skills publish",
    "clawhub:whoami": "pnpm -C packages/skills run clawhub:whoami",
    "clawhub:inspect:skills": "pnpm -C packages/skills run clawhub:inspect",
    "clawhub:publish:skills:dry-run": "pnpm -C packages/skills run clawhub:publish:dry-run",
    "clawhub:publish:skills": "pnpm -C packages/skills run clawhub:publish",
    "publish:core": "pnpm run publish:sdk && pnpm run publish:cli",
    "publish:all": "pnpm run publish:sdk && pnpm run publish:cli && pnpm run publish:skills"
  }
}
