{
  "name": "finebi-openclaw-skill",
  "version": "0.1.3",
  "description": "A FineBI plugin for OpenClaw providing advanced data analysis, visualization and reporting skills.",
  "type": "module",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "bin": {
    "finebi-cli": "dist/cli.js",
    "finebi-skill": "dist/cli.js",
    "finebi-openclaw-skill": "dist/cli.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "README.md",
    "package.json",
    "openclaw.plugin.json"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "openclaw-plugin",
    "openclaw-skill",
    "finebi-skill",
    "finebi-cli",
    "data-analysis-plugin",
    "business-intelligence"
  ],
  "author": "zsmj1994",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "publishConfig": {
    "access": "public"
  }
}