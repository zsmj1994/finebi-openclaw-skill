{
  "name": "finebi-openclaw-skill",
  "version": "0.2.14",
  "description": "A FineBI plugin for OpenClaw providing advanced data analysis, visualization and reporting skills.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "finebi-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "skills",
    "README.md"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "openclaw-plugin",
    "openclaw-skill",
    "finebi-skill",
    "finebi-cli",
    "data-analysis-plugin",
    "business-intelligence"
  ],
  "author": "zsmj1994",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}