{
  "name": "finebi-cli",
  "version": "0.2.18",
  "description": "Command-line tools for FineBI data analysis, exports, and dashboard workflows.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "finebi-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "clean": "if (Test-Path dist) { Remove-Item -Recurse -Force dist }",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run test && pnpm run typecheck && pnpm run build",
    "publish:npm": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/publish-npm-tarball.ps1 ."
  },
  "keywords": [
    "finebi",
    "finebi-cli",
    "dashboard-export",
    "data-analysis",
    "business-intelligence"
  ],
  "author": "zsmj1994",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "finebi-querydata-sdk": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
