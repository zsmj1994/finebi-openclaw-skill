{
  "name": "finebi-querydata-sdk",
  "version": "1.0.1",
  "description": "SDK for querying FineBI dashboard data and applying filters in a simulated browser environment.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "if (Test-Path dist) { Remove-Item -Recurse -Force dist }",
    "start": "ts-node src/index.ts",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run build",
    "publish:npm": "npm publish --access public"
  },
  "keywords": [
    "finebi",
    "query",
    "filter",
    "sdk"
  ],
  "author": "zsmj1994",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "jsdom": "^24.0.0",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
